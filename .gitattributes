* text=auto

# Source and docs should stay LF across platforms
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf

# Windows-native scripts should stay CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf