  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "npm run compile",
    "package": "vsce package",
    "rebuild": "npm run test:catalog && npm run test:regression && npm run compile && npm run package && node install.js",
    "test:catalog": "node tests/catalog-integrity.test.js",
    "test:commands": "node tests/command-validation.test.js",
    "test:regression": "node scripts/run-regression-tests.js",
    "start": "npm run rebuild",
    "vscode:prepublish": "npm run compile",
    "mcp:build": "cd mcp-server && npm run build",
    "mcp:start": "cd mcp-server && node dist/index.js",
    "mcp:dev": "cd mcp-server && npm run dev",
    "mcp:inspect": "cd mcp-server && npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:ui:cards": "npx playwright test tests/ui/all-cards-webview.spec.ts",
    "audit:coverage": "node scripts/audit-test-coverage.js",
    "audit:coverage:detailed": "node scripts/audit-test-coverage.js --detailed",
    "audit:coverage:json": "node scripts/audit-test-coverage.js --json",
    "check-architecture": "node scripts/check-architecture.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  },
  "icon": "icon.png",
  "dependencies": {
    "diff": "^8.0.3"
  }
}
