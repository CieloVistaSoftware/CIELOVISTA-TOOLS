    "menus": {
      "explorer/context": [
        {
          "command": "cvs.terminal.setFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation@100"
        },
        {
          "command": "cvs.explorer.openFolderAsRoot",
          "when": "explorerResourceIsFolder",
          "group": "navigation@99"
        },
        {
          "command": "cvs.python.runFile",
          "when": "resourceExtname == .py",
          "group": "navigation@90"
        }
      ],
      "commandPalette": [
        {
          "command": "cvs.terminal.setFolder",
          "when": "true"
        },
        {
          "command": "cvs.python.runFile",
          "when": "true"
        },
        {
          "command": "cvs.config.edit",
          "when": "true"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cvs.terminal.copyOutputClipboard",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "terminalFocus"
      },
      {
        "command": "cvs.openai.explain",
        "key": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "cvs.openai.generateDocstring",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "CieloVista Tools",
      "properties": {
        "cielovistaTools.copilotRulesEnforcer.autoEnforce": {
          "type": "boolean",
          "default": true,
          "description": "Apply rules automatically on workspace open."
        },
        "cielovistaTools.homeProjectPath": {
          "type": "string",
          "default": "C:\\Users\\jwpmi\\Downloads\\VSCode\\projects\\cielovista-tools",
          "description": "Absolute path to your CieloVista home project root used by 'Project: Open Home'."
        },
        "cielovistaTools.npmScriptDescriptions": {
          "type": "object",
          "default": {},
          "description": "Map of custom descriptions for npm scripts. Keys use 'relative-package-json-path::script-name'. Prefer editing via command: 'NPM Scripts: Add/Edit Description'."
        },
        "cielovistaTools.anthropic.apiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key — used for AI-powered README fixes and generation. Store in User settings, never workspace."
        },
        "cielovistaTools.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key — store in User settings, never workspace."
        },
        "cielovistaTools.openai.model": {
          "type": "string",
          "default": "gpt-4o",
          "enum": [
            "gpt-4o",
            "gpt-4-turbo",
            "gpt-3.5-turbo"
          ],
          "description": "OpenAI model to use."
        },
        "cielovistaTools.features.copilotRulesEnforcer": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Copilot Rules Enforcer feature."
        },
        "cielovistaTools.features.copilotOpenSuggested": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Copilot Open Suggested File feature."
        },
        "cielovistaTools.features.terminalCopyOutput": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Terminal Copy Output feature."
        },
        "cielovistaTools.features.terminalSetFolder": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Terminal Set Folder feature."
        },
        "cielovistaTools.features.terminalFolderTracker": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Terminal Folder Tracker feature."
        },
        "cielovistaTools.features.terminalPromptShortener": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Terminal Prompt Shortener feature."
        },
        "cielovistaTools.features.cssClassHover": {
          "type": "boolean",
          "default": true,
          "description": "Enable the CSS Class Hover feature."
        },
        "cielovistaTools.features.pythonRunner": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Python Runner feature."
        },
        "cielovistaTools.features.htmlTemplateDownloader": {
          "type": "boolean",
          "default": true,
          "description": "Enable the HTML Template Downloader feature."
        },
        "cielovistaTools.features.openaiChat": {
          "type": "boolean",
          "default": true,
          "description": "Enable the OpenAI Chat feature."
        },
        "cielovistaTools.features.cvsCommandLauncher": {
          "type": "boolean",
          "default": true,
          "description": "Enable the CVS Command Launcher feature."
        },
        "cielovistaTools.features.projectHomeOpener": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Project Home Opener feature."
        },
        "cielovistaTools.features.npmCommandLauncher": {
          "type": "boolean",
          "default": true,
          "description": "Enable the NPM Command Launcher feature."
        },
        "cielovistaTools.features.mcpServerScaffolder": {
          "type": "boolean",
          "default": true,
