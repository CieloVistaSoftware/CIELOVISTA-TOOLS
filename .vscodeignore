# Source — compiled + bundled to out/ and mcp-server/dist/ by esbuild
src/**
esbuild.mjs

# node_modules — not needed; all deps are inlined by esbuild bundler
node_modules/**

# Tests — not needed at runtime
tests/**
playwright.config.ts
playwright-report/**
test-results/**

# MCP server — include only compiled dist; exclude source and dev files
mcp-server/src/**
mcp-server/tsconfig.json
mcp-server/install-config.mjs

# Dev scripts — not needed at runtime
scripts/**
patch-help-docs.js
install.js
rebuild.ps1
debug-coverage.js
start-test-watch.bat

# Build artifacts
*.vsix
**/*.map
.scripts/**
**/logs/**
launcher-debug.png

# Config and meta files not needed in extension
.vscode/**
.claude/**
.github/**
tsconfig.json
package-lock.json
config.json
CLAUDE.md
Downloads/**
data/**
*.code-workspace

# Root-level temp/working files
_*
*.log
*.tmp
*.bat

# Docs that are developer-facing only (not user-facing)
docs/**
TEST-VIEW-A-DOC.md
ViewADoc.md
copilot-rules.md
