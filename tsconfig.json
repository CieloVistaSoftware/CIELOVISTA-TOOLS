{
  "compilerOptions": {
    "module":           "commonjs",
    "target":           "ES2020",
    "lib":              ["ES2020"],
    "outDir":           "./out",
    "rootDir":          "./src",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "sourceMap":        true,
    "declaration":      true,
    "resolveJsonModule": true,
    "paths": {
      "vscode": ["./node_modules/@types/vscode"]
    },
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "vscode"]
  },
  "include":  [
    "src/**/*",
    "extension.ts"
  ],
  "exclude":  [
    "node_modules",
    "out",
    "**/*.test.ts",
    "dist",
    "test.backup.*",
    ".vscode-test",
    "playwright-report",
    "test-results",
    "Tests/**/*",
    "tests/**/*",
    "vscode-copilot-auto-continue/**"
  ]
}
